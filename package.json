{
    "name": "ideal-list",
    "version": "1.0.0",
    "description": "邮箱实时监控桌面应用 - Vue3 + Electron",
    "main": "dist-electron/main/index.js",
    "author": "",
    "license": "MIT",
    "private": true,
    "type": "module",
    "scripts": {
        "copy-preload": "node -e \"require('fs').mkdirSync('dist-electron/preload',{recursive:true}); require('fs').copyFileSync('electron/preload/index.cjs','dist-electron/preload/index.js')\"",
        "dev": "npm run copy-preload && vite --host",
        "build": "vue-tsc --noEmit && vite build && npm run copy-preload && electron-builder",
        "preview": "vite preview",
        "build:win": "NODE_TLS_REJECT_UNAUTHORIZED=0 node scripts/build-win.js"
    },
    "dependencies": {
        "imapflow": "^1.2.10",
        "mailparser": "^3.9.3",
        "vue": "^3.4.21"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.0.4",
        "cross-env": "^7.0.3",
        "electron": "^29.4.6",
        "electron-builder": "^24.13.3",
        "typescript": "^5.4.2",
        "vite": "^5.1.5",
        "vite-plugin-electron": "^0.28.4",
        "vite-plugin-electron-renderer": "^0.14.5",
        "vue-tsc": "^2.0.6"
    },
    "build": {
        "appId": "com.ideal-list.app",
        "productName": "邮箱监控",
        "directories": {
            "output": "release"
        },
        "win": {
            "target": [
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "signAndEditExecutable": false,
            "icon": "email.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "installerLanguages": [
                "zh_CN"
            ],
            "shortcutName": "邮箱监控"
        }
    }
}
